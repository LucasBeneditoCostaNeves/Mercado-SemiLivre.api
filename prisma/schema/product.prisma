model CategoryProducts {
  id        String    @id @default(uuid())
  name      String
  status    Boolean
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now())
  Product   Product[]
}

model Product {
  id                  String           @id @default(uuid())
  name                String
  status              Boolean
  category_product_id String
  categoryProducts    CategoryProducts @relation(fields: [category_product_id], references: [id])
  seller_user_id      String
  user                User             @relation(fields: [seller_user_id], references: [id])
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @default(now())
}
