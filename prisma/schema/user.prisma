model Profile {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
  User      User[]

  @@map("profiles")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  status    Boolean
  profile   Profile  @relation(fields: [profileId], references: [id])
  profileId String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}
